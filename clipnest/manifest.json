{
  "manifest_version": 3,
  "name": "ClipNest — 剪贴板历史管理",
  "version": "1.0.0",
  "description": "跨浏览器剪贴板历史管理插件，支持文字、链接和图片的自动捕获与管理",
  "permissions": [
    "storage",
    "notifications",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClipNest",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}